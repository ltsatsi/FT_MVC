@model FT1.ViewModels.HomeViewModel

@{
    ViewData["Title"] = "Home Page";
}

<!-- Hero Section -->
@if (!User.Identity!.IsAuthenticated)
{
    <section class="hero-section position-relative d-flex justify-content-center align-items-center">
        <!-- Overlay -->
        <div class="position-absolute top-0 start-0 w-100 h-100" style="background-color: rgba(0,0,0,0.5);"></div>

        <!-- Centered content -->
        <div class="container text-center text-white position-relative">
            <h1 class="display-6 fw-bold">Click, track, plan save!</h1>
            <p class="lead">
                Can't keep track of your fuel, or your drive just feels <strong>not</strong> economical? <br />
                Track your fuel usage easily and efficiently!
            </p>
            <a asp-controller="Account" asp-action="Register" class="btn btn-primary mt-2">Get Started</a>
        </div>
    </section>
}
else
{
    <section class="hero-section position-relative d-flex justify-content-center align-items-center">
        <!-- Overlay -->
        <div class="position-absolute top-0 start-0 w-100 h-100" style="background-color: rgba(0,0,0,0.5);"></div>

        <!-- Centered content -->
        <div class="container text-center text-white position-relative p-3" style="background-color: #1d1d3d75">
            <h2 style="color: #ff8c00; font-weight: 400;">Fuel Ordering</h2>
            <p class="fw-bold">Welcome, @Model.Name.TrimEnd()!</p>
        </div>
    </section>
}

<div class="landing-page-container text-center py-3">
    <!-- Features Section -->
    <section class="features py-5">
        <div class="container">
            <div class="row g-4">
                <div class="col-md-4">
                    <div class="card h-100 shadow-sm">
                        <div class="card-header" style="background-color:#1d1d3d; color:#dee2e6;">Track Fuel</div>
                        <div class="card-body">
                            <p class="card-text">
                                Keep a detailed log of your vehicle refuels and monitor consumption trends.
                            </p>
                        </div>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="card h-100 shadow-sm">
                        <div class="card-header" style="background-color:#1d1d3d; color:#dee2e6;">Analytics</div>
                        <div class="card-body">
                            <p class="card-text">
                                Get insights with fuel usage statistics, averages, and distance tracking.
                            </p>
                        </div>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="card h-100 shadow-sm">
                        <div class="card-header" style="background-color:#1d1d3d; color:#dee2e6;">User Friendly</div>
                        <div class="card-body">
                            <p class="card-text">
                                Simple and intuitive interface designed for quick data entry and easy navigation.
                            </p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>
</div>

<style>
    /* Landing Page Styling */

    .card {
        border: 1px solid #dee2e6;
        background-color: #ffffff;
    }

    .card-header {
        font-weight: 600;
        font-size: 1.1rem;
    }

    .btn-primary {
        background-color: #ff8c00;
        border-color: #ff8c00;
        color: #ffffff;
        font-weight: 500;
    }

        .btn-primary:hover {
            background-color: #ffa733;
            border-color: #ffa733;
            color: #ffffff;
        }

    .btn-outline-primary {
        border-color: #26408B;
        color: #26408B;
        font-weight: 500;
    }

        .btn-outline-primary:hover {
            background-color: #26408B;
            border-color: #26408B;
            color: #ffffff;
        }

    .hero h1 {
        font-size: 3rem;
    }

    .features .card {
        transition: transform 0.2s;
    }

        .features .card:hover {
            transform: translateY(-5px);
        }
</style>