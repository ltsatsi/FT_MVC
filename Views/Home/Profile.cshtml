@model FT1.ViewModels.ProfileViewModel

@{
    ViewData["Title"] = "Profile";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col col-md-10">
            <div class="row">
                <!-- Profile image -->
                <div class="col-2">
                    <img src="https://placehold.co/100x100" />
                </div>

                <!-- user details -->
                <div class="col">
                    <h4>@Model.FirstName @(Model.LastName ?? "")</h4>
                    <p class="text-muted"><span class="text-decoration-underline text-primary">@Model.Email</span> - Joined @Model.CreatedOn.ToString("d MMM, yyyy")</p>
                </div>
            </div>
        </div>

        <!-- manage vehicles section -->
        <div class="col-md-10 my-2">
            <a asp-controller="Vehicle" asp-action="Index"
               class="d-flex justify-content-between align-items-center
              text-decoration-none text-dark
              p-3 border rounded bg-white shadow-sm">

                <span class="fw-semibold">Manage Vehicles</span>

                <span class="text-muted">
                    <i class="bi bi-chevron-right"></i>
                </span>

            </a>
        </div>

        <!-- browse fillups -->
        <div class="col-md-10 my-2">
            <a asp-controller="FillUp" asp-action="Index"
               class="d-flex justify-content-between align-items-center
              text-decoration-none text-dark
              p-3 border rounded bg-white shadow-sm">

                <span class="fw-semibold">Browse fill ups</span>

                <span class="text-muted">
                    <i class="bi bi-chevron-right"></i>
                </span>

            </a>
        </div>
    </div>
</div>