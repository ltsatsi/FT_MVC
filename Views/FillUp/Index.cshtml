@model IEnumerable<FT1.Models.FillUp>

@{
    ViewData["Title"] = "Fill Up History";
}

<div class="container mt-4">

    <div class="d-flex justify-content-between align-items-center mb-3">
        <h3 class="fw-bold" style="color:#0b1f3b;">@ViewData["Title"]</h3>
        <a asp-action="Create" class="btn btn-primary btn-sm">Add New Fill Up</a>
    </div>

    <div class="row">
        @foreach (var fill in Model)
        {
            <div class="col-md-6 mb-3">
                <a asp-action="Details" asp-route-id="@fill.FillUpId" class="card fillup-card shadow-sm text-decoration-none">
                    <div class="card-body d-flex justify-content-between align-items-center">
                        <div>
                            <strong>@fill.Vehicle!.Make @fill.Vehicle.Model</strong>
                            <br />
                            <small class="text-muted">@fill.DateOfFill.ToShortDateString()</small>
                            <br />
                            <small class="text-muted">@fill.Litre L | R @fill.Price | @fill.Odometer km</small>
                        </div>
                        <i class="bi bi-chevron-right text-muted fs-4"></i>
                    </div>
                </a>
            </div>
        }
    </div>

</div>

<style>
    .fillup-card {
        background-color: #ffffff;
        border-radius: 0.5rem;
        border: 1px solid #dee2e6;
        color: #0b1f3b;
        transition: transform 0.2s, box-shadow 0.2s;
        display: block;
    }

        .fillup-card:hover {
            transform: translateY(-3px);
            box-shadow: 0 6px 20px rgba(0,0,0,0.1);
            text-decoration: none;
        }

        .fillup-card small {
            display: block;
        }

        .fillup-card i {
            color: #6c757d;
        }

        .btn-primary {
        background: #26408B;
        border-color: #26408B;
    }

    .btn-primary:hover {
        background: #26408B;
        border-color: #26408B;
    }
</style>