@model FT1.Models.FillUp

@{
    ViewData["Title"] = "Edit";
}

<h1>Edit</h1>

<h4>FillUp</h4>
<hr />
<div class="row">
    <div class="col-md-4">
        <form asp-action="Edit">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <input type="hidden" asp-for="FillUpId" />
            <div class="form-group">
                <label asp-for="StationName" class="control-label"></label>
                <input asp-for="StationName" class="form-control" />
                <span asp-validation-for="StationName" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="Price" class="control-label"></label>
                <input asp-for="Price" class="form-control" />
                <span asp-validation-for="Price" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="Litre" class="control-label"></label>
                <input asp-for="Litre" class="form-control" />
                <span asp-validation-for="Litre" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="Odometer" class="control-label"></label>
                <input asp-for="Odometer" class="form-control" />
                <span asp-validation-for="Odometer" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="DateOfFill" class="control-label"></label>
                <input asp-for="DateOfFill" class="form-control" />
                <span asp-validation-for="DateOfFill" class="text-danger"></span>
            </div>
            <div class="form-group">
                <input type="hidden" asp-for="VehicleId" value="@ViewBag.VehicleId" />
            </div>
            <div class="form-group">
                <input type="submit" value="Save" class="btn btn-primary" />
            </div>
        </form>
    </div>
</div>

<div>
    <a asp-action="Index">Back to List</a>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
