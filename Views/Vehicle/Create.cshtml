@model FT1.Models.Vehicle

@{
    ViewData["Title"] = "Add Vehicle";
}

<div class="container py-4">

    <!-- Page Header -->
    <div class="mb-4">
        <h3 class="fw-bold" style="color:#0b1f3b;">Add Vehicle</h3>
        <p class="text-muted mb-0">
            Register a vehicle to start tracking fuel usage, costs, and performance.
        </p>
    </div>

    <div class="row g-4">

        <!-- LEFT: FORM -->
        <div class="col-lg-8">

            <div class="card border-0 shadow-sm">
                <div class="card-body p-4">

                    <form asp-action="Create">

                        @if (!ViewData.ModelState.IsValid)
                        {
                            <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>
                        }

                        <input type="hidden" asp-for="Id" value="@ViewData["UserId"]" />

                        <!-- SECTION -->
                        <div class="mb-4">
                            <h6 class="fw-bold text-uppercase text-muted">Vehicle Information</h6>
                            <small class="text-muted">
                                Enter accurate vehicle details for proper tracking.
                            </small>
                        </div>

                        <!-- Registration -->
                        <div class="mb-3">
                            <label asp-for="Registration" class="form-label fw-semibold"></label>
                            <input asp-for="Registration" class="form-control" placeholder="e.g. HPF094FS" />
                            <small class="text-muted">
                                Use the official number plate format.
                            </small>
                            <span asp-validation-for="Registration" class="text-danger"></span>
                        </div>

                        <!-- Make -->
                        <div class="mb-3">
                            <label asp-for="Make" class="form-label fw-semibold"></label>
                            <input asp-for="Make" class="form-control" placeholder="e.g. Volkswagen" />
                            <small class="text-muted">
                                Manufacturer of the vehicle.
                            </small>
                            <span asp-validation-for="Make" class="text-danger"></span>
                        </div>

                        <!-- Model -->
                        <div class="mb-4">
                            <label asp-for="Model" class="form-label fw-semibold"></label>
                            <input asp-for="Model" class="form-control" placeholder="e.g. Polo Vivo" />
                            <small class="text-muted">
                                Specific model of the vehicle.
                            </small>
                            <span asp-validation-for="Model" class="text-danger"></span>
                        </div>

                        <hr class="my-4" />

                        <!-- ACTIONS -->
                        <div class="d-flex justify-content-between align-items-center">
                            <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>

                            <button type="submit" class="btn btn-primary px-4">
                                Create Vehicle
                            </button>
                        </div>

                    </form>
                </div>
            </div>
        </div>

        <!-- RIGHT: GUIDANCE PANEL -->
        <div class="col-lg-4">

            <div class="card border-0 shadow-sm bg-light">
                <div class="card-body p-4">

                    <h6 class="fw-bold mb-3">How to complete this form</h6>

                    <ul class="ps-3 text-muted small">
                        <li class="mb-2">
                            Enter the correct <strong>registration number</strong>.
                        </li>
                        <li class="mb-2">
                            Provide the <strong>vehicle make</strong> (manufacturer).
                        </li>
                        <li class="mb-2">
                            Specify the <strong>model</strong> clearly.
                        </li>
                        <li class="mb-2">
                            This vehicle will be linked to all fuel records.
                        </li>
                    </ul>

                    <hr />

                    <div class="p-3 rounded" style="background:#fff3cd;">
                        <small class="text-dark">
                            💡 Tip: Consistent naming helps when managing multiple vehicles.
                        </small>
                    </div>

                </div>
            </div>

        </div>

    </div>
</div>

<style>
    .card {
        border-radius: 12px;
    }

    .btn-primary {
        background-color: #1d1d3d;
        border-color: #1d1d3d;
        font-weight: 500;
    }

        .btn-primary:hover {
            background-color: #0b1f3b;
            border-color: #0b1f3b;
        }

    .form-control {
        border-radius: 8px;
    }

        .form-control:focus {
            border-color: #0b1f3b;
            box-shadow: 0 0 0 0.15rem rgba(11,31,59,0.15);
        }
</style>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}