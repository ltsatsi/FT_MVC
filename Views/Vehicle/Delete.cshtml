@model FT1.Models.Vehicle

@{
    ViewData["Title"] = "Delete";
}

<div class="container mt-5">

    <div class="card shadow-sm border-0">
        <div class="card-header bg-danger text-white">
            <h4 class="mb-0">Delete Vehicle</h4>
        </div>

        <div class="card-body">

            <p class="text-danger fw-bold">
                Are you sure you want to delete this vehicle?
            </p>

            <hr />

            <div class="row mb-2">
                <div class="col-12 col-md-4 fw-semibold text-muted small">Make</div>
                <div class="col-12 col-md-8">@Model.Make</div>
            </div>

            <div class="row mb-2">
                <div class="col-12 col-md-4 fw-semibold text-muted small">Model</div>
                <div class="col-12 col-md-8">@Model.Model</div>
            </div>

            <div class="row mb-2">
                <div class="col-12 col-md-4 fw-semibold text-muted small">Resistration</div>
                <div class="col-12 col-md-8">@Model.Registration</div>
            </div>

            <form asp-action="Delete">
                <input type="hidden" asp-for="VehicleId" />

                <button type="submit" class="btn btn-danger">
                    Delete Record
                </button>

                <a asp-action="Index" class="btn btn-secondary ms-2">
                    Cancel
                </a>
            </form>

        </div>
    </div>

</div>
