@model IEnumerable<FT1.Models.Vehicle>

@{
    ViewData["Title"] = "Index";
}

<h4>Manage vehicles</h4>
<hr />

<p>
    <a asp-controller="Vehicle" asp-action="Create" class="btn btn-dark">Add <i class="bg bi-plus"></i></a>
</p>
@foreach(var item in Model)
{
    <div class="d-flex justify-content-between align-items-center
                          p-2 my-3 border rounded bg-white shadow-sm row">
        <p><i class="bi bi-car-front"></i> @item.Registration <span class="text-success">Active</span></p>
        <p>@item.Make</p>
        <p>@item.Model</p>
    </div>
}