@model IEnumerable<FT1.Models.Vehicle>

@{
    ViewData["Title"] = "Vehicles";
}

<div class="container mt-4">

    <div class="d-flex justify-content-between align-items-center mb-3">
        <div>
            <h4 class="fw-bold" style="color:#0b1f3b;">Manage Vehicles</h4>
            <small class="text-muted">Your registered vehicles</small>
        </div>

        <a asp-controller="Vehicle"
           asp-action="Create"
           class="btn btn-primary btn-sm">
            <i class="bi bi-plus"></i> Add Vehicle
        </a>
    </div>

    <hr />

    @foreach (var item in Model)
    {
        <a asp-action="Details" asp-route-id="@item.VehicleId" class="text-decoration-none text-black">

            <div class="vehicle-card d-flex justify-content-between align-items-center
                            p-3 mb-2 border rounded bg-white shadow-sm">

                <div>
                    <strong>
                        <i class="bi bi-car-front me-2"></i>
                        @item.Registration
                    </strong>
                    <br />
                    <small class="text-muted">@item.Make @item.Model</small>
                </div>

                <div class="d-flex align-items-center gap-3">

                    <i class="bi bi-chevron-right text-muted"></i>
                </div>

            </div>
        </a>
    }

</div>

<style>
    .vehicle-card {
        transition: transform 0.15s ease, box-shadow 0.15s ease;
    }

        .vehicle-card:hover {
            transform: translateY(-2px);
            box-shadow: 0 6px 18px rgba(0,0,0,0.08);
        }

    .btn-primary {
        background-color: #ff8c00;
        border-color: #ff8c00;
    }

        .btn-primary:hover {
            background-color: #e67e00;
            border-color: #e67e00;
        }

    .btn-outline-primary {
        border-color: #0b1f3b;
        color: #0b1f3b;
    }

        .btn-outline-primary:hover {
            background-color: #0b1f3b;
            color: white;
        }
</style>